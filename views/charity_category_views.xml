<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_elks_charity_category_tree" model="ir.ui.view">
        <field name="name">elks.charity.category.tree</field>
        <field name="model">elks.charity.category</field>
        <field name="arch" type="xml">
            <list string="Grand Lodge Charity Categories">
                <field name="code"/>
                <field name="name"/>
                <field name="gl_section"/>
                <field name="sequence"/>
                <field name="x_auto_create_task" string="Auto-Create"
                       widget="boolean_toggle"/>
                <field name="x_show_on_website" string="Show on Website"
                       widget="boolean_toggle"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_elks_charity_category_form" model="ir.ui.view">
        <field name="name">elks.charity.category.form</field>
        <field name="model">elks.charity.category</field>
        <field name="arch" type="xml">
            <form string="Charity Category">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="gl_section"/>
                        <field name="sequence"/>
                        <field name="x_auto_create_task"/>
                        <field name="x_show_on_website"/>
                        <field name="active"/>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elks_charity_category" model="ir.actions.act_window">
        <field name="name">Charity Categories</field>
        <field name="res_model">elks.charity.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
