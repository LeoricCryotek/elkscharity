<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Charity Activity field + Log Hours button to calendar event form -->
    <record id="view_calendar_event_form_elkscharity" model="ir.ui.view">
        <field name="name">calendar.event.form.elkscharity</field>
        <field name="model">calendar.event</field>
        <field name="inherit_id" ref="calendar.view_calendar_event_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Elks Charity Activity">
                    <group>
                        <field name="x_charity_task_id"
                               options="{'no_create': True}"/>
                        <field name="x_charity_category_id" readonly="1"
                               invisible="not x_charity_task_id"/>
                        <field name="x_charity_category_code" readonly="1"
                               invisible="not x_charity_task_id"/>
                        <!--
                          Recurring Contribution link: visible once a Charity
                          Activity is picked (the domain narrows the dropdown
                          to contributions on the same task). Both 'no_create'
                          and 'no_open' are left at their defaults so editors
                          can use the dropdown's "Create and Edit..." option
                          to open the full Recurring Contribution form
                          (frequency, end date, cash/non-cash, recipient,
                          etc.) without leaving the event.
                        -->
                        <field name="x_charity_contribution_id"
                               invisible="not x_charity_task_id"
                               options="{'no_quick_create': True}"/>
                    </group>
                    <group>
                        <button name="action_log_charity_hours"
                                type="object"
                                string="Log Volunteer Hours"
                                class="btn-primary"
                                icon="fa-clock-o"
                                invisible="not x_charity_task_id"/>
                        <button name="action_open_charity_contribution"
                                type="object"
                                string="Open Contribution"
                                icon="fa-external-link"
                                invisible="not x_charity_contribution_id"/>
                        <button name="action_create_next_contribution_occurrence"
                                type="object"
                                string="Create Next Occurrence"
                                class="btn-secondary"
                                icon="fa-plus-circle"
                                invisible="not x_charity_contribution_id"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
