<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_elks_timecard_report_wizard_form" model="ir.ui.view">
        <field name="name">elks.timecard.report.wizard.form</field>
        <field name="model">elks.timecard.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Timecard Report">
                <group>
                    <group string="Pay Period">
                        <field name="pay_period"/>
                        <field name="period_month"
                               invisible="pay_period == 'custom'"/>
                        <field name="period_year"
                               invisible="pay_period == 'custom'"
                               options="{'format': false}"/>
                        <field name="period_display" readonly="1"
                               string="Selected Period"/>
                        <field name="date_from"
                               readonly="pay_period != 'custom'"
                               force_save="1"/>
                        <field name="date_to"
                               readonly="pay_period != 'custom'"
                               force_save="1"/>
                    </group>
                    <group string="Employees">
                        <field name="employee_ids" widget="many2many_tags"
                               placeholder="Leave empty for all paid staff..."
                               domain="[('department_id.name', '!=', 'Volunteers')]"/>
                    </group>
                </group>
                <!-- Warning banner for employees with no hours -->
                <div class="alert alert-warning" role="alert"
                     invisible="not no_hours_warning">
                    <field name="no_hours_warning" readonly="1" nolabel="1"/>
                </div>
                <separator string="Download CSV"/>
                <group invisible="not csv_file">
                    <field name="csv_file" filename="csv_filename"/>
                    <field name="csv_filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_previous_period"
                            string="◀ Previous Period" type="object"
                            class="btn-secondary"/>
                    <button name="action_next_period"
                            string="Next Period ▶" type="object"
                            class="btn-secondary"/>
                    <div class="flex-grow-1"/>
                    <button name="action_print_pdf" string="Preview"
                            type="object" class="btn-primary"
                            icon="fa-eye"/>
                    <button name="action_download_pdf" string="Download PDF"
                            type="object" class="btn-secondary"
                            icon="fa-download"/>
                    <button name="action_export_csv" string="Export CSV"
                            type="object" class="btn-secondary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_elks_timecard_report_wizard" model="ir.actions.act_window">
        <field name="name">Timecard Report</field>
        <field name="res_model">elks.timecard.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
