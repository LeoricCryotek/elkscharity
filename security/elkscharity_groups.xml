<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="res_groups_privilege_elkscharity" model="res.groups.privilege">
            <field name="name">Elks Charity</field>
            <field name="category_id" ref="base.module_category_productivity"/>
            <field name="sequence">85</field>
        </record>

        <record id="group_elkscharity_user" model="res.groups">
            <field name="name">Volunteer</field>
            <field name="privilege_id" ref="res_groups_privilege_elkscharity"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_elkscharity_secretary" model="res.groups">
            <field name="name">Secretary</field>
            <field name="privilege_id" ref="res_groups_privilege_elkscharity"/>
            <field name="sequence">10</field>
            <field name="implied_ids" eval="[(4, ref('group_elkscharity_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
