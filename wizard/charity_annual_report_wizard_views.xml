<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_charity_annual_report_wizard_form"
            model="ir.ui.view">
        <field name="name">elks.charity.annual.report.wizard.form</field>
        <field name="model">elks.charity.annual.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Charity Annual Report">
                <group>
                    <group string="Select Charity Project">
                        <field name="project_id"
                               options="{'no_create': True}"/>
                    </group>
                </group>
                <footer>
                    <button string="Preview"
                            name="action_preview"
                            type="object" class="btn-primary"
                            icon="fa-eye"/>
                    <button string="Download PDF"
                            name="action_download_pdf"
                            type="object" class="btn-secondary"
                            icon="fa-download"/>
                    <button string="Close" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_charity_annual_report_wizard"
            model="ir.actions.act_window">
        <field name="name">Charity Annual Report</field>
        <field name="res_model">elks.charity.annual.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
