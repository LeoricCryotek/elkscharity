<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_log_hours_wizard_form" model="ir.ui.view">
        <field name="name">elks.charity.log.hours.wizard.form</field>
        <field name="model">elks.charity.log.hours.wizard</field>
        <field name="arch" type="xml">
            <form string="Log Charity Hours">
                <sheet>
                    <div class="oe_title">
                        <h2>Log Volunteer Hours</h2>
                    </div>
                    <group>
                        <group>
                            <field name="event_id" readonly="1"
                                   invisible="not event_id"/>
                            <field name="task_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="charity_category_id"
                                   readonly="1"/>
                            <field name="employee_id"/>
                            <field name="is_helper"/>
                        </group>
                        <group>
                            <field name="event_date"/>
                            <field name="duration_hours"/>
                            <field name="miles"/>
                            <field name="cash_value"/>
                            <field name="non_cash_value"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Short description..."/>
                    <field name="notes" placeholder="Notes for the Secretary..."/>
                </sheet>
                <footer>
                    <button name="action_create_timesheet" type="object"
                            string="Log Hours" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
