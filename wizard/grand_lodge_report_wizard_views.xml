<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_grand_lodge_report_wizard_form"
            model="ir.ui.view">
        <field name="name">elks.grand.lodge.report.wizard.form</field>
        <field name="model">elks.grand.lodge.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Grand Lodge Charitable Giving Report">
                <!-- Choose state -->
                <group invisible="state != 'choose'">
                    <group string="Date Range">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Filters (optional)">
                        <field name="project_ids" widget="many2many_tags"
                               options="{'no_create': True}"
                               placeholder="All charity projects"/>
                        <field name="task_ids" widget="many2many_tags"
                               options="{'no_create': True}"
                               placeholder="All events"/>
                        <field name="employee_ids" widget="many2many_tags"
                               options="{'no_create': True}"
                               placeholder="All employees/volunteers"/>
                        <field name="category_ids" widget="many2many_tags"
                               options="{'no_create': True}"
                               placeholder="All GL categories"/>
                    </group>
                </group>

                <!-- Download state -->
                <group invisible="state != 'download'">
                    <group>
                        <field name="csv_file" filename="csv_filename"/>
                        <field name="csv_filename" invisible="1"/>
                    </group>
                </group>

                <field name="state" invisible="1"/>

                <footer>
                    <button string="Preview"
                            name="action_print_report"
                            type="object" class="btn-primary"
                            icon="fa-eye"
                            invisible="state != 'choose'"/>
                    <button string="Download PDF"
                            name="action_download_pdf"
                            type="object" class="btn-secondary"
                            icon="fa-download"
                            invisible="state != 'choose'"/>
                    <button string="Export CSV (Grand Lodge Format)"
                            name="action_export_csv"
                            type="object" class="btn-secondary"
                            invisible="state != 'choose'"/>
                    <button string="Close" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_grand_lodge_report_wizard"
            model="ir.actions.act_window">
        <field name="name">Grand Lodge Charity Report</field>
        <field name="res_model">elks.grand.lodge.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
