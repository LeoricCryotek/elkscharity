<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_charity_annual" model="ir.actions.report">
        <field name="name">Grand Lodge Charity Annual Report</field>
        <field name="model">project.project</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">elkscharity.report_charity_annual</field>
        <field name="report_file">elkscharity.report_charity_annual</field>
        <field name="binding_model_id" ref="project.model_project_project"/>
        <field name="binding_type">report</field>
        <!-- Only show the print menu entry on charity parent projects -->
        <field name="domain">[('x_is_charity_parent', '=', True)]</field>
    </record>

    <!-- Companion PDF report for download -->
    <record id="action_report_charity_annual_pdf" model="ir.actions.report">
        <field name="name">Grand Lodge Charity Annual Report (PDF)</field>
        <field name="model">project.project</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">elkscharity.report_charity_annual</field>
        <field name="report_file">elkscharity.report_charity_annual</field>
        <field name="binding_model_id" ref="project.model_project_project"/>
        <field name="binding_type">report</field>
        <field name="domain">[('x_is_charity_parent', '=', True)]</field>
    </record>

    <template id="report_charity_annual">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-if="doc.x_is_charity_parent">
                    <t t-set="settings"
                       t-value="doc.env['elks.lodge.settings'].sudo().search([], limit=1)"/>
                        <div class="page" style="font-size: 11px;">
                            <!-- ===== LODGE HEADER WITH LOGOS ===== -->
                            <table style="width: 100%; margin-bottom: 10px; border: none;">
                                <tr>
                                    <td style="width: 15%; text-align: center; vertical-align: middle; border: none; padding: 0;">
                                        <t t-if="settings and settings.logo_primary">
                                            <img t-att-src="image_data_uri(settings.logo_primary)"
                                                 style="max-height: 80px; max-width: 100px;"
                                                 alt="Elks USA"/>
                                        </t>
                                    </td>
                                    <td style="text-align: center; vertical-align: middle; border: none; padding: 0 10px;">
                                        <h2 style="font-size: 22px; margin: 0 0 2px 0; color: #333;">
                                            <t t-if="settings and settings.name">
                                                <span t-field="settings.name"/>
                                            </t>
                                            <t t-else="">Elks Lodge</t>
                                            <t t-if="settings and settings.lodge_number">
                                                #<span t-field="settings.lodge_number"/>
                                            </t>
                                        </h2>
                                        <p style="color: #777; font-size: 11px; margin: 0;">
                                            Benevolent and Protective Order of Elks
                                        </p>
                                        <h3 style="font-size: 18px; margin: 6px 0 0 0; color: #003366;">
                                            Grand Lodge Charity Records
                                        </h3>
                                        <p style="font-size: 12px; color: #333; margin: 4px 0 0 0;">
                                            <span t-field="doc.name"/>
                                            <t t-if="doc.x_lodge_year">
                                                — Lodge Year: <span t-field="doc.x_lodge_year"/>
                                            </t>
                                            <t t-if="doc.x_is_closed"> — CLOSED</t>
                                        </p>
                                    </td>
                                    <td style="width: 15%; text-align: center; vertical-align: middle; border: none; padding: 0;">
                                        <t t-if="settings and settings.logo_lodge">
                                            <img t-att-src="image_data_uri(settings.logo_lodge)"
                                                 style="max-height: 80px; max-width: 100px;"
                                                 alt="Lodge Logo"/>
                                        </t>
                                    </td>
                                </tr>
                            </table>
                            <div style="border-top: 2px solid #003366; margin-bottom: 15px;"/>

                            <!-- Empty-state: project exists but no tasks logged -->
                            <t t-if="not doc.task_ids">
                                <div class="alert alert-info">
                                    <strong>No charitable activities have been
                                    logged for this lodge year yet.</strong>
                                    Create activity tasks under this project
                                    and log volunteer hours against them, then
                                    reprint to see the Grand Lodge breakdown.
                                </div>
                            </t>

                            <!-- Overall totals -->
                            <h4 class="mt-4">Annual Totals</h4>
                            <table class="table table-sm table-bordered">
                                <tr>
                                    <td><strong>Total Participants Served:</strong></td>
                                    <td class="text-end">
                                        <span t-field="doc.x_total_participants"/>
                                    </td>
                                    <td><strong>Total Hours:</strong></td>
                                    <td class="text-end">
                                        <span t-field="doc.x_total_hours"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Total Miles:</strong></td>
                                    <td class="text-end">
                                        <span t-field="doc.x_total_miles"/>
                                    </td>
                                    <td><strong>Total Cash Donated:</strong></td>
                                    <td class="text-end">
                                        <span t-field="doc.x_total_cash"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Non-Cash Value:</strong></td>
                                    <td class="text-end">
                                        <span t-field="doc.x_total_non_cash"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td colspan="2"/>
                                </tr>
                            </table>

                            <!-- Per-category breakdown -->
                            <t t-set="categories"
                               t-value="request.env['elks.charity.category'].search([], order='code')"/>
                            <t t-foreach="categories" t-as="cat">
                                <t t-set="cat_tasks"
                                   t-value="doc.task_ids.filtered(lambda t: t.x_charity_category_id.id == cat.id)"/>
                                <t t-if="cat_tasks">
                                    <h4 class="mt-4">
                                        <span t-field="cat.name"/> — <span t-field="cat.code"/>
                                    </h4>
                                    <table class="table table-sm table-bordered">
                                        <thead>
                                            <tr class="table-secondary">
                                                <th>Date</th>
                                                <th>Program</th>
                                                <th class="text-end">Head Count (B)</th>
                                                <th class="text-end"># Elks (C)</th>
                                                <th class="text-end"># Helpers (D)</th>
                                                <th class="text-end">Elks Hrs (E)</th>
                                                <th class="text-end">Hlp Hrs (F)</th>
                                                <th class="text-end">Elks Mi (G)</th>
                                                <th class="text-end">Hlp Mi (H)</th>
                                                <th class="text-end">Non-Cash (I)</th>
                                                <th class="text-end">Cash (J)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="cat_tasks" t-as="task">
                                                <td><span t-field="task.x_event_date"/></td>
                                                <td><span t-field="task.name"/></td>
                                                <td class="text-end">
                                                    <span t-field="task.x_total_head_count"/>
                                                </td>
                                                <td class="text-end">
                                                    <span t-field="task.x_elks_count"/>
                                                </td>
                                                <td class="text-end">
                                                    <span t-field="task.x_helper_count"/>
                                                </td>
                                                <td class="text-end">
                                                    <span t-field="task.x_elks_hours"/>
                                                </td>
                                                <td class="text-end">
                                                    <span t-field="task.x_helper_hours"/>
                                                </td>
                                                <td class="text-end">
                                                    <span t-field="task.x_elks_miles"/>
                                                </td>
                                                <td class="text-end">
                                                    <span t-field="task.x_helper_miles"/>
                                                </td>
                                                <td class="text-end">
                                                    <span t-field="task.x_non_cash_total"
                                                          t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                                </td>
                                                <td class="text-end">
                                                    <span t-field="task.x_cash_total"
                                                          t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                                </td>
                                            </tr>
                                            <tr class="table-info">
                                                <td colspan="2"><strong>Annual Total</strong></td>
                                                <td class="text-end">
                                                    <strong>
                                                        <t t-esc="sum(cat_tasks.mapped('x_total_head_count'))"/>
                                                    </strong>
                                                </td>
                                                <td class="text-end">
                                                    <strong>
                                                        <t t-esc="sum(cat_tasks.mapped('x_elks_count'))"/>
                                                    </strong>
                                                </td>
                                                <td class="text-end">
                                                    <strong>
                                                        <t t-esc="sum(cat_tasks.mapped('x_helper_count'))"/>
                                                    </strong>
                                                </td>
                                                <td class="text-end">
                                                    <strong>
                                                        <t t-esc="'%.1f' % sum(cat_tasks.mapped('x_elks_hours'))"/>
                                                    </strong>
                                                </td>
                                                <td class="text-end">
                                                    <strong>
                                                        <t t-esc="'%.1f' % sum(cat_tasks.mapped('x_helper_hours'))"/>
                                                    </strong>
                                                </td>
                                                <td class="text-end">
                                                    <strong>
                                                        <t t-esc="'%.1f' % sum(cat_tasks.mapped('x_elks_miles'))"/>
                                                    </strong>
                                                </td>
                                                <td class="text-end">
                                                    <strong>
                                                        <t t-esc="'%.1f' % sum(cat_tasks.mapped('x_helper_miles'))"/>
                                                    </strong>
                                                </td>
                                                <td class="text-end">
                                                    <strong>
                                                        $<t t-esc="'%.2f' % sum(cat_tasks.mapped('x_non_cash_total'))"/>
                                                    </strong>
                                                </td>
                                                <td class="text-end">
                                                    <strong>
                                                        $<t t-esc="'%.2f' % sum(cat_tasks.mapped('x_cash_total'))"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </t>
                            </t>

                            <div class="mt-5 text-center text-muted small">
                                Generated from the Elks Lodge management system.
                                Only <strong>validated</strong> hours are included above.
                            </div>
                        </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
