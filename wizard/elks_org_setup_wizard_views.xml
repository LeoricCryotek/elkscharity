<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_elks_org_setup_wizard_form" model="ir.ui.view">
        <field name="name">elks.charity.elks_org_setup_wizard.form</field>
        <field name="model">elks.charity.elks_org_setup_wizard</field>
        <field name="arch" type="xml">
            <form string="Elks.org Push Setup">
                <sheet>
                    <div class="oe_title">
                        <h1>Elks.org Push Setup</h1>
                        <p class="text-muted">
                            Two integration paths for pushing charity
                            contributions to elks.org.  <strong>Use the
                            Chrome extension</strong> — it's the reliable
                            one.  Server-side Playwright is kept as a
                            fallback in case elks.org drops their bot
                            detection.
                        </p>
                    </div>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- PRIMARY PATH — Chrome extension               -->
                    <!-- ═══════════════════════════════════════════ -->
                    <div class="alert alert-success" role="alert">
                        <h3 style="margin-top:0;">✅ Recommended: Chrome Extension</h3>
                        <p>
                            The extension runs in the Secretary's Chrome
                            browser.  When elks.org is logged in in
                            another tab, the extension quietly polls
                            Odoo for validated contributions and submits
                            them using the browser's live session.  No
                            elks.org credentials stored anywhere.
                        </p>
                        <p style="margin-bottom:0;">
                            <strong>One-time install per Secretary:</strong>
                        </p>
                        <ol>
                            <li>
                                Get the extension folder onto the
                                Secretary's computer.  Simplest:
                                <code>git clone</code> the elkscharity
                                repo, then point Chrome at the
                                <code>extension/</code> subfolder.
                                Or zip it up on the server and email
                                it over.
                            </li>
                            <li>
                                In Chrome, open <code>chrome://extensions/</code>.
                            </li>
                            <li>
                                Turn on <strong>Developer mode</strong>
                                (top right).
                            </li>
                            <li>
                                Click <strong>Load unpacked</strong>,
                                pick the <code>extension/</code> folder.
                            </li>
                            <li>
                                The "Elks.org Push" icon appears in
                                the toolbar.
                            </li>
                            <li>
                                In Odoo, go to <em>Preferences → Elks.org
                                Credentials → Regenerate API Key</em> and
                                copy the shown key.
                            </li>
                            <li>
                                Click the extension icon.  Paste the
                                Odoo URL + API Key.  Check <em>Enabled</em>,
                                click <em>Save</em>.
                            </li>
                            <li>
                                Log into <a href="https://www.elks.org"
                                target="_blank">elks.org</a> in a normal
                                tab.  Leave it open.
                            </li>
                        </ol>
                        <p>
                            <strong>Extension folder path on this server:</strong>
                            <br/>
                            <field name="extension_path_hint"
                                   readonly="1" nolabel="1"/>
                        </p>
                    </div>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- LEGACY PATH — Playwright                     -->
                    <!-- ═══════════════════════════════════════════ -->
                    <group string="Server-Side Playwright (Legacy Fallback)">
                        <group>
                            <field name="playwright_installed"
                                   widget="boolean_toggle"
                                   readonly="1"/>
                            <field name="playwright_version" readonly="1"
                                   invisible="not playwright_installed"/>
                            <field name="chromium_installed"
                                   widget="boolean_toggle"
                                   readonly="1"/>
                            <field name="chromium_path" readonly="1"
                                   invisible="not chromium_installed"/>
                        </group>
                    </group>

                    <div class="alert alert-warning" role="alert">
                        <strong>Heads-up:</strong> as of July 2026,
                        elks.org's login blocks Playwright-driven
                        Chromium — even with stealth-mode overrides.
                        Server-side push is <em>not currently working</em>.
                        Install it anyway if you want to test whether
                        elks.org has since relaxed the check; otherwise
                        just use the Chrome extension.
                    </div>

                    <div style="margin: 20px 0;">
                        <button name="action_check_status"
                                type="object"
                                string="Refresh Status"
                                class="btn-secondary"
                                icon="fa-refresh"/>
                        <button name="action_install_all"
                                type="object"
                                string="Install Playwright + Chromium"
                                class="btn-secondary"
                                icon="fa-download"
                                confirm="This will download Chromium
                                (~180 MB) into the Odoo venv.  Takes
                                1–3 minutes.  Server-side push is
                                currently blocked by elks.org's bot
                                detection — you may not need this.
                                Proceed?"/>
                    </div>

                    <field name="installation_log" widget="text"
                           readonly="1"
                           placeholder="Playwright installation output will appear here (only if you click Install)."
                           options="{'resizable': false}"
                           style="font-family: Consolas, monospace; font-size: 12px; min-height: 200px; background: #f5f5f5; padding: 12px; border-radius: 4px;"/>
                </sheet>
                <footer>
                    <button string="Close"
                            class="btn-primary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_elks_org_setup_wizard"
            model="ir.actions.act_window">
        <field name="name">Elks.org Push Setup</field>
        <field name="res_model">elks.charity.elks_org_setup_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
