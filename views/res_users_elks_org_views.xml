<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add an "Elks.org Credentials" tab to the standard Preferences
         form so any user can set their own login without needing
         admin access.  SELF_READABLE_FIELDS / SELF_WRITEABLE_FIELDS
         in res_users_elks_org.py grants the ACL for these fields on
         the current user record. -->
    <record id="view_users_form_preferences_elks_org"
            model="ir.ui.view">
        <field name="name">res.users.preferences.form.elkscharity</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Elks.org Credentials"
                      name="elks_org_credentials">
                    <group>
                        <group string="Browser Extension (Recommended)">
                            <field name="x_elks_org_api_key"
                                   password="True"
                                   readonly="1"/>
                            <field name="x_elks_org_api_key_created"
                                   readonly="1"
                                   invisible="not x_elks_org_api_key_created"/>
                            <button name="action_regenerate_elks_org_api_key"
                                    type="object"
                                    string="Regenerate API Key"
                                    class="btn-primary"
                                    confirm="Any Elks.org Push Chrome extension using the old key will stop working until you paste in the new one.  Continue?"/>
                        </group>
                        <group string="Server-Side Auto-Push (Legacy)">
                            <field name="x_elks_org_enabled"/>
                            <field name="x_elks_org_login"
                                   placeholder="Your elks.org member number or email"/>
                            <field name="x_elks_org_password"
                                   password="True"
                                   placeholder="Your elks.org password"/>
                            <field name="x_elks_org_last_success"
                                   readonly="1"
                                   invisible="not x_elks_org_last_success"/>
                        </group>
                    </group>
                    <p class="text-muted small">
                        <strong>Recommended path — Chrome extension:</strong>
                        install the Elks.org Push extension in your browser
                        (see <em>Elks Charity → Configuration → Elks.org
                        Push Setup</em> for install instructions), paste
                        the API key above into the extension's popup, and
                        keep an elks.org tab open + logged in.  The
                        extension polls Odoo for pending submissions and
                        pushes them silently using your real browser
                        session.  Bypasses elks.org's server-side bot
                        detection because it IS a real browser doing real
                        submissions.
                    </p>
                    <p class="text-muted small">
                        <strong>Legacy path — server-side auto-push:</strong>
                        the credentials below drive a Playwright/Chromium
                        login on the Odoo server.  Currently blocked by
                        elks.org's bot detection (as of July 2026).  Kept
                        as a fallback in case elks.org drops the check.
                        If left unused, "Mark Submitted Manually" on each
                        contribution is always available.
                    </p>
                    <p class="text-muted small">
                        <strong>Security note:</strong> the API key gives
                        the extension full push privileges as your user.
                        Treat it like a password.  Regenerate it if your
                        computer is compromised or you install the
                        extension somewhere you don't fully control.
                    </p>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Same tab on the full admin res.users form.  Not strictly
         required because Preferences covers the self-service case,
         but useful for admins who set up credentials on behalf of
         a Secretary during initial rollout. -->
    <record id="view_users_form_elks_org" model="ir.ui.view">
        <field name="name">res.users.form.elkscharity</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Elks.org Credentials"
                      name="elks_org_credentials">
                    <group>
                        <group string="Browser Extension">
                            <field name="x_elks_org_api_key"
                                   password="True"
                                   readonly="1"/>
                            <field name="x_elks_org_api_key_created"
                                   readonly="1"/>
                            <button name="action_regenerate_elks_org_api_key"
                                    type="object"
                                    string="Regenerate API Key"
                                    class="btn-primary"/>
                        </group>
                        <group string="Server-Side Auto-Push (Legacy)">
                            <field name="x_elks_org_enabled"/>
                            <field name="x_elks_org_login"/>
                            <field name="x_elks_org_password"
                                   password="True"/>
                            <field name="x_elks_org_last_success"
                                   readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
