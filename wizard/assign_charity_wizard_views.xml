<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard form -->
    <record id="view_assign_charity_wizard_form" model="ir.ui.view">
        <field name="name">elks.assign.charity.wizard.form</field>
        <field name="model">elks.assign.charity.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Charity Activity">
                <group>
                    <div class="alert alert-info" role="alert">
                        Assign a charity activity to
                        <strong><field name="attendance_count" nolabel="1" class="d-inline"/></strong>
                        selected attendance record(s).
                    </div>
                </group>
                <group>
                    <field name="charity_task_id"
                           options="{'no_create': True}"/>
                    <field name="use_worked_hours"/>
                    <field name="fixed_charity_hours"
                           invisible="use_worked_hours"
                           widget="float_time"/>
                    <field name="is_helper"/>
                </group>
                <footer>
                    <button name="action_apply" type="object"
                            string="Apply" class="btn-primary"/>
                    <button string="Cancel" special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Server action: opens the wizard from list view Action menu -->
    <record id="action_assign_charity_attendance" model="ir.actions.act_window">
        <field name="name">Assign Charity Activity</field>
        <field name="res_model">elks.assign.charity.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="binding_view_types">list</field>
    </record>

</odoo>
